# SVY platform — environment template. Copy to .env for local dev.
# On Vercel, set these in Project → Settings → Environment Variables.
# NEVER commit a real .env (this repo is public).
NODE_ENV=development

# --- Database (required) ----------------------------------------------------
# Local dev (docker-compose): postgresql://svy:svy@localhost:5433/svy?schema=public
# Production: a Neon Postgres URL — use the POOLED connection string on Vercel.
DATABASE_URL="postgresql://svy:svy@localhost:5433/svy?schema=public"

# --- Auth (required in production) ------------------------------------------
# Generate strong 32+ char secrets:  openssl rand -base64 48
JWT_ACCESS_SECRET="change-me-32+chars"
JWT_REFRESH_SECRET="change-me-32+chars"
ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_TTL="30d"

# --- Public -----------------------------------------------------------------
# Production: your Vercel URL, e.g. https://svy.vercel.app
NEXT_PUBLIC_APP_URL="http://localhost:3001"
NEXT_PUBLIC_APP_NAME="Savynt"

# --- Optional ---------------------------------------------------------------
# Rate limiter is in-memory by default; Redis is NOT required to run.
REDIS_URL="redis://localhost:6379"

# Bootstrap the OWNER account (scripts/make-owner.ts). Pass inline when running,
# do not store real values in this public file.
# OWNER_EMAIL=
# OWNER_PASSWORD=
# OWNER_PHONE=
# OWNER_FIRST_NAME=

# Phase 2 — fill when wiring these up
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=svy-audio
# ANTHROPIC_API_KEY=   # AI grading of writing/speaking
